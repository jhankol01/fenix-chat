# ─── Server ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────────
DATABASE_URL=

# ─── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Resend (Email) ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
