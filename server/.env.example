# ─── Backblaze B2 Storage ────────────────────────────────────────────────────────
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=

# ─── Tenor GIF API ───────────────────────────────────────────────────────────
TENOR_API_KEY=
